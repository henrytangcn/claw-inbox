{
  "manifest_version": 3,
  "name": "Claw Inbox",
  "version": "0.1.0",
  "description": "Send current page to OpenClaw via bridge",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://localhost:*/*", "http://127.0.0.1:*/*", "https://*/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "icons": {}
}
